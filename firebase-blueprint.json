{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Shared To-Do List",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "Todo": {
      "title": "Todo",
      "description": "A shared to-do item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "completed", "createdBy", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A user's schedule or note for a specific date",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "date", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/schedules/{date}": {
      "schema": { "$ref": "#/entities/Schedule" },
      "description": "User schedules"
    },
    "/todos/{todoId}": {
      "schema": { "$ref": "#/entities/Todo" },
      "description": "Shared to-do items"
    }
  }
}
